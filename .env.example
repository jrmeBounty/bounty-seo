# ─── Database (Required) ─────────────────────────────────────────────────────
# These will be automatically created by Neon Launchpad (https://neon.new).
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL_POOLER=postgres://user:password@host-pooler.neon.tech/dbname?sslmode=require

# ─── Authentication (Required) ───────────────────────────────────────────────
# Generate a secure random string (min 32 characters):
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=replace_me_with_32_plus_char_random_string
BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth (Required for login) ──────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ─── Google Maps/Places API (Required for rankings) ─────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Places API (New), Maps JavaScript API
GOOGLE_MAPS_API_KEY=AIzaSy...

# ─── Sentry Error Tracking (Optional but Recommended) ────────────────────────
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
# Used for error monitoring and email alerts
VITE_SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx

# ─── Email Notifications (Future - Step 7) ──────────────────────────────────
# For automated email reports and alerts
# RESEND_API_KEY=re_xxx

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
# In production: NODE_ENV=production
